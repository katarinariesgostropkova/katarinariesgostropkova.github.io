---
import BaseLayout from './BaseLayout.astro';
import CaseStudyMetaTable from '../components/CaseStudyMetaTable.astro';
import CaseStudySidebar from '../components/CaseStudySidebar.astro';
import MobileNavPill from '../components/MobileNavPill.astro';
import CaseCallout from '../components/CaseCallout.astro';

interface Props {
  title: string;
  description: string;
  eyebrow?: string;
  heroImage?: { src: string; alt: string };
  meta: {
    company: string;
    team: string;
    role: string;
    timeline: string;
  };
  sections: Array<{ id: string; label: string }>;
  callout?: { label: string; body: string };
}

const {
  title,
  description,
  eyebrow = 'Case study',
  heroImage,
  meta,
  sections,
  callout,
} = Astro.props;
---

<BaseLayout title={title} description={description}>

  <!-- Gate slot: PasswordGate renders here on locked pages.
       Hidden by default; body.gate-locked makes it visible. -->
  <slot name="gate" />

  <!-- All case study content wrapped so body.gate-locked can hide it. -->
  <div data-case-content>

    <!-- Hero block: eyebrow → title → description → optional image -->
    <section class="case-hero" data-case-hero>
      <div class="case-hero__inner">
        <p class="case-hero__eyebrow">{eyebrow}</p>
        <h1 class="case-hero__title">{title}</h1>
        <p class="case-hero__description">{description}</p>

        {heroImage && (
          <div class="case-hero__image-wrap">
            <img
              class="case-hero__image"
              src={heroImage.src}
              alt={heroImage.alt}
              loading="eager"
            />
          </div>
        )}
      </div>
    </section>

    <!-- Meta table: Company / Team / My role / Timeline -->
    <div class="case-meta-wrap">
      <CaseStudyMetaTable meta={meta} />
    </div>

    <!-- Callout: renders between meta table and body sections when present -->
    {callout && (
      <div class="case-callout-wrap">
        <CaseCallout label={callout.label} data-callout>
          {callout.body}
        </CaseCallout>
      </div>
    )}

    <!-- Body: sidebar (desktop) + content column -->
    <div class="case-body" data-case-study>
      <CaseStudySidebar sections={sections} />
      <article class="case-body__content">
        <slot />
      </article>
    </div>

    <!-- Mobile pill + sheet: hidden on desktop, sidebar takes over -->
    <MobileNavPill sections={sections} />

  </div><!-- /data-case-content -->

</BaseLayout>

<!-- Animation ⑫ — mobile pill + sheet functional behaviour -->
<script>
  import '../scripts/mobile-nav-pill.js';
</script>

<style>
  /* ── HERO ─────────────────────────────────────── */
  .case-hero {
    background: var(--color-canvas);
    padding: var(--space-16) 0 var(--space-10);
  }

  .case-hero__inner {
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: 0 var(--padding-desktop);
  }

  .case-hero__eyebrow {
    font-family: var(--font-sans);
    font-size: var(--font-size-meta);
    font-weight: var(--weight-medium);
    color: var(--color-teal);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    margin-bottom: var(--space-4);
  }

  .case-hero__title {
    font-family: var(--font-serif);
    font-size: var(--font-size-hero);
    font-weight: var(--weight-light);
    color: var(--text-primary);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    margin-bottom: var(--space-4);
    max-width: 820px;
  }

  .case-hero__description {
    font-family: var(--font-sans);
    font-size: var(--font-size-subhead);
    font-weight: var(--weight-regular);
    color: var(--text-secondary);
    line-height: var(--leading-normal);
    max-width: 680px;
  }

  /* Hero image — linen-padded slot, no browser chrome */
  .case-hero__image-wrap {
    margin-top: var(--space-10);
    background: var(--color-linen);
    padding: var(--space-6);
    border-radius: var(--radius-md);
    border: 0.5px solid var(--color-deep-tide-08);
    max-width: 820px;
  }

  .case-hero__image {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius-sm);
  }

  /* ── META TABLE WRAPPER ───────────────────────── */
  .case-meta-wrap {
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: 0 var(--padding-desktop);
  }

  /* ── CALLOUT WRAPPER ─────────────────────────── */
  .case-callout-wrap {
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: 0 var(--padding-desktop);
  }

  /* ── BODY: sidebar + content grid ────────────── */
  .case-body {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: var(--space-12);
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: var(--space-10) var(--padding-desktop) var(--space-20);
    align-items: start;
  }

  /*
   * Sidebar is shown here via display:grid child.
   * Below 1024px, grid collapses to 1fr; sidebar hides itself via
   * display:none in CaseStudySidebar.astro (avoids Astro scoping issues
   * with :first-child selectors targeting child component roots).
   */

  .case-body__content {
    min-width: 0; /* prevents grid blowout on long words */
    max-width: 720px;
    overflow-x: clip;
  }

  /* ── TABLET ───────────────────────────────────── */
  @media (max-width: 1199px) {
    .case-hero__inner,
    .case-meta-wrap,
    .case-callout-wrap,
    .case-body {
      padding-left: var(--padding-tablet);
      padding-right: var(--padding-tablet);
    }
  }

  /* ── MOBILE: single column, sidebar hidden ────── */
  @media (max-width: 1023px) {
    .case-hero {
      padding: var(--space-10) 0 var(--space-8);
    }

    .case-hero__title {
      font-size: 36px;
    }

    .case-hero__inner,
    .case-meta-wrap,
    .case-callout-wrap,
    .case-body {
      padding-left: var(--padding-mobile);
      padding-right: var(--padding-mobile);
    }

    .case-body {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .case-hero__title {
      font-size: 28px;
    }
  }
</style>
