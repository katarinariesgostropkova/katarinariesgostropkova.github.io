---
import '../styles/global.css';
import '../styles/typography.css';
import '../styles/animations.css';
import Header from '../components/Header.astro';
import MobileOverlay from '../components/MobileOverlay.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Katarina Riesgo Stropkova — Research-Led Product Designer',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Favicons & manifest -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="96x96" href="/assets/favicons/favicon-96x96.png" />
    <link rel="apple-touch-icon" href="/assets/favicons/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#1c2b3a" />

    <!-- Open Graph -->
    <meta property="og:image" content="https://katarinariesgostropkova.github.io/assets/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Google Fonts — exact load string, do not modify -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to main content</a>
    <Header />
    <MobileOverlay />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
