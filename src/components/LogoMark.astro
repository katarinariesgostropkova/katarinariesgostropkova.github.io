---
interface Props {
  size?: number;
  variant?: 'light' | 'dark';
  decorative?: boolean;
}

const { size = 26, variant = 'light', decorative = false } = Astro.props;
const width = Math.round(size * 120 / 150);
const isDark = variant === 'dark';
---

<svg
  viewBox="0 0 120 150"
  xmlns="http://www.w3.org/2000/svg"
  width={width}
  height={size}
  class:list={['logo-mark', isDark && 'logo-mark--dark']}
  aria-hidden={decorative ? 'true' : undefined}
  role={!decorative ? 'img' : undefined}
  aria-label={!decorative ? 'Katarina Riesgo Stropkova logo mark' : undefined}
>
  <path
    class="mark-teardrop"
    d="M60 8C60 8 14 58 14 96C14 126 35 148 60 148C85 148 106 126 106 96C106 58 60 8 60 8Z"
  />
  <ellipse
    class="mark-oval"
    cx="60"
    cy="100"
    rx="18"
    ry="26"
  />
  <circle
    class="mark-dot"
    cx="60"
    cy="70"
    r="8"
  />
</svg>

<style>
.mark-teardrop {
  fill: var(--color-deep-tide);
}

.mark-oval {
  fill: none;
  stroke: var(--color-teal);
  stroke-width: 9;
}

.mark-dot {
  fill: var(--color-rose);
}

/* Dark surface: teardrop becomes semi-transparent ghost */
.logo-mark--dark .mark-teardrop {
  fill: var(--border-dark-soft);    /* rgba(247,246,242,0.08) */
  stroke: var(--text-dark-045);     /* rgba(247,246,242,0.45) */
  stroke-width: 2;
}
</style>
