---
interface Props {
  state: 'live' | 'placeholder';
  name?: string;
  initials?: string;
  subtitle?: string;
  trait?: string;
  quote?: string;
}

const { state, name, initials, subtitle, trait, quote } = Astro.props;
---

{state === 'live' ? (
  <article class="rec-card rec-card--live">
    <div class="rec-card__header">
      <div class="rec-card__avatar" aria-hidden="true">{initials}</div>
      <div class="rec-card__meta">
        <span class="rec-card__name">{name}</span>
        <span class="rec-card__subtitle">{subtitle}</span>
      </div>
    </div>
    {trait && (
      <p class="rec-card__trait">{trait}</p>
    )}
    {quote && (
      <p class="rec-card__quote">{quote}</p>
    )}
  </article>
) : (
  <div class="rec-card rec-card--placeholder" aria-label="Recommendation coming soon">
    <svg
      class="rec-card__lock"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
      <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
    </svg>
    <p class="rec-card__placeholder-label">Recommendation coming soon</p>
  </div>
)}

<style>
.rec-card {
  border-radius: var(--radius-lg);
  padding: var(--space-6);
}

.rec-card--live {
  background: var(--color-canvas);
  border: 1px solid rgba(28, 43, 58, 0.08);
}

.rec-card--placeholder {
  background: transparent;
  border: 1px dashed rgba(28, 43, 58, 0.20);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--space-3);
  min-height: 180px;
}

.rec-card__header {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  margin-bottom: var(--space-3);
}

.rec-card__avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: rgba(43, 165, 165, 0.15);
  color: var(--color-teal);
  font-family: var(--font-sans);
  font-weight: var(--weight-medium);
  font-size: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.rec-card__meta {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.rec-card__name {
  font-family: var(--font-serif);
  font-weight: var(--weight-light);
  font-size: 18px;
  color: var(--text-primary);
  line-height: var(--leading-snug);
}

.rec-card__subtitle {
  font-family: var(--font-sans);
  font-weight: var(--weight-regular);
  font-size: var(--font-size-meta);
  color: var(--text-muted);
}

.rec-card__trait {
  font-family: var(--font-sans);
  font-weight: var(--weight-medium);
  font-size: var(--font-size-meta);
  color: var(--color-teal);
  letter-spacing: var(--tracking-widest);
  text-transform: uppercase;
  margin-top: var(--space-3);
  margin-bottom: 0;
}

.rec-card__quote {
  font-family: var(--font-sans);
  font-weight: var(--weight-regular);
  font-size: var(--font-size-body);
  color: var(--text-body);
  line-height: var(--leading-normal);
  margin-top: var(--space-3);
  margin-bottom: 0;
}

.rec-card__lock {
  color: var(--text-muted);
}

.rec-card__placeholder-label {
  font-family: var(--font-sans);
  font-weight: var(--weight-regular);
  font-size: var(--font-size-body);
  color: var(--text-muted);
  margin: 0;
  text-align: center;
}
</style>
