---
interface Props {
  number: string;
  title: string;
  id: string;
}

const { number, title, id } = Astro.props;
---

<h2 id={id} class="section-heading">
  <span class="section-heading__number">{number}</span>
  <span class="section-heading__title">{title}</span>
</h2>

<style>
  .section-heading {
    /*
     * 22px per DESIGN_DECISIONS.md §2.3 ("Cormorant 300 22px") and CLAUDE.md §5.3
     * ("22px (case headings)"). No global token at 22px — scoped here to avoid
     * adding to global.css per Phase 3B-2 constraints.
     */
    --_heading-size: 22px;
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    margin-top: var(--space-12);
    margin-bottom: var(--space-6);
  }

  .section-heading__number {
    font-family: var(--font-sans);
    font-size: var(--font-size-meta); /* 12px — closest token; spec says 10px, no 10px token */
    font-weight: var(--weight-medium);
    color: var(--color-rose);
    line-height: 1;
    flex-shrink: 0;
  }

  .section-heading__title {
    font-family: var(--font-serif);
    font-size: var(--_heading-size);
    font-weight: var(--weight-light);
    color: var(--text-primary);
    line-height: var(--leading-snug);
  }
</style>
