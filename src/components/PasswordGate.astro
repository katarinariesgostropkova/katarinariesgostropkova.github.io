---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'work'>;
}

const { entry } = Astro.props;

const encodedTitle = encodeURIComponent(entry.data.title);
const mailtoHref =
  `mailto:katka.stropkova@gmail.com` +
  `?subject=Requesting%20access%20to%20${encodedTitle}` +
  `&body=Hi%20Katarina%2C%0A%0AI%27d%20like%20to%20request%20access%20to%20your%20` +
  `${encodedTitle}%20case%20study.%0A%0A--%0AYour%20Name%0AYour%20Role%2FCompany`;
---

<div class="password-gate" data-password-gate>
  <div class="password-gate__card">

    <!-- Lock icon (same path data as WorkCardThumbnail, scaled up) -->
    <svg
      class="password-gate__lock-icon"
      width="32"
      height="36"
      viewBox="0 0 14 16"
      aria-hidden="true"
      focusable="false"
    >
      <rect
        x="2" y="7" width="10" height="8" rx="1.5"
        fill="none"
        stroke="currentColor"
        stroke-width="1.2"
      />
      <path
        d="M4 7 V4.5 a3 3 0 0 1 6 0 V7"
        fill="none"
        stroke="currentColor"
        stroke-width="1.2"
        stroke-linecap="round"
      />
    </svg>

    <!-- Eyebrow -->
    <p class="password-gate__eyebrow">Protected Case Study</p>

    <!-- Title -->
    <h1 class="password-gate__title">{entry.data.title}</h1>

    <!-- Description -->
    <p class="password-gate__description">{entry.data.description}</p>

    <!-- Spacer -->
    <div class="password-gate__spacer" aria-hidden="true"></div>

    <!-- Password form -->
    <form class="password-gate__form" novalidate>
      <label class="password-gate__label" for="password-gate-input">
        Password
      </label>
      <input
        class="password-gate__input"
        id="password-gate-input"
        type="password"
        name="password"
        autocomplete="off"
        aria-describedby="gate-error"
      />
      <button class="password-gate__submit btn btn--rose" type="submit">
        Unlock case study →
      </button>
      <p
        class="password-gate__error"
        id="gate-error"
        role="alert"
        aria-live="polite"
        aria-hidden="true"
      >
        Incorrect password. Please try again.
      </p>
    </form>

    <!-- Separator -->
    <hr class="password-gate__separator" aria-hidden="true" />

    <!-- Request access -->
    <div class="password-gate__request">
      <p class="password-gate__request-text">Don't have a password?</p>
      <a class="password-gate__request-link" href={mailtoHref}>
        Request access for {entry.data.title} →
      </a>
    </div>

  </div>
</div>

<script>
  import '../scripts/password-gate.js';
</script>

<style>
  /* ── GATE CONTAINER ─────────────────────────────── */
  /* Full-viewport flex container so card stays centered
     between header and footer */
  .password-gate {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 120px); /* approx header + footer clearance */
    padding: var(--space-10) var(--padding-desktop);
  }

  /* ── GATE CARD ──────────────────────────────────── */
  .password-gate__card {
    background: var(--color-canvas);
    border-radius: var(--radius-lg); /* 12px */
    box-shadow: var(--shadow-overlay);
    border-top: 2px solid var(--color-rose);
    width: 100%;
    max-width: 480px;
    padding: var(--space-10);
    display: flex;
    flex-direction: column;
  }

  /* ── LOCK ICON ──────────────────────────────────── */
  .password-gate__lock-icon {
    color: var(--color-rose);
    margin-bottom: var(--space-4);
    flex-shrink: 0;
  }

  /* ── EYEBROW ────────────────────────────────────── */
  .password-gate__eyebrow {
    font-family: var(--font-sans);
    font-size: var(--font-size-meta);
    font-weight: var(--weight-medium);
    color: var(--color-teal);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    margin-bottom: var(--space-3);
  }

  /* ── TITLE ──────────────────────────────────────── */
  .password-gate__title {
    font-family: var(--font-serif);
    font-size: var(--font-size-section); /* 28px */
    font-weight: var(--weight-light);
    color: var(--text-primary);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    margin-bottom: 0;
  }

  /* ── DESCRIPTION ────────────────────────────────── */
  .password-gate__description {
    font-family: var(--font-sans);
    font-size: var(--font-size-body);
    font-weight: var(--weight-regular);
    color: var(--text-body);
    line-height: var(--leading-normal);
    margin-top: var(--space-3);
  }

  /* ── SPACER ─────────────────────────────────────── */
  .password-gate__spacer {
    height: var(--space-6);
  }

  /* ── FORM ───────────────────────────────────────── */
  .password-gate__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .password-gate__label {
    font-family: var(--font-sans);
    font-size: var(--font-size-meta);
    font-weight: var(--weight-medium);
    color: var(--color-teal);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  .password-gate__input {
    font-family: var(--font-sans);
    font-size: var(--font-size-body);
    color: var(--text-primary);
    background: var(--color-canvas);
    border: 1px solid rgba(28, 43, 58, 0.15);
    border-radius: var(--radius-md); /* 8px */
    padding: var(--space-3);
    width: 100%;
    outline: none;
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .password-gate__input:focus {
    border-color: var(--color-teal);
  }

  /* Error state — shake + teal border.
     Reduced-motion: border + message only, no animation. */
  @keyframes gate-shake {
    0%, 100% { transform: translateX(0); }
    25%       { transform: translateX(-4px); }
    50%       { transform: translateX(4px); }
    75%       { transform: translateX(-4px); }
  }

  .password-gate__input--error {
    animation: gate-shake 300ms ease-out;
    border-color: var(--color-teal);
  }

  @media (prefers-reduced-motion: reduce) {
    .password-gate__input--error {
      animation: none;
    }
  }

  .password-gate__submit {
    align-self: flex-start;
    margin-top: var(--space-1);
  }

  /* ── ERROR MESSAGE ──────────────────────────────── */
  .password-gate__error {
    font-family: var(--font-sans);
    font-size: var(--font-size-meta);
    color: var(--color-rose);
    margin: 0;
  }

  /* Hidden by default; shown via aria-hidden="false" in JS */
  .password-gate__error[aria-hidden='true'] {
    display: none;
  }

  /* ── SEPARATOR ──────────────────────────────────── */
  .password-gate__separator {
    border: none;
    border-top: 0.5px solid rgba(28, 43, 58, 0.10);
    margin: var(--space-6) 0;
  }

  /* ── REQUEST ACCESS ─────────────────────────────── */
  .password-gate__request {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .password-gate__request-text {
    font-family: var(--font-sans);
    font-size: var(--font-size-meta);
    font-weight: var(--weight-regular);
    color: var(--text-muted);
    margin: 0;
  }

  .password-gate__request-link {
    font-family: var(--font-sans);
    font-size: var(--font-size-body);
    font-weight: var(--weight-regular);
    color: var(--color-rose);
    text-decoration: none;
    transition: text-decoration var(--duration-fast);
  }

  .password-gate__request-link:hover {
    text-decoration: underline;
  }

  /* ── MOBILE ─────────────────────────────────────── */
  @media (max-width: 599px) {
    .password-gate {
      padding: var(--space-8) var(--padding-mobile);
      align-items: flex-start;
      padding-top: var(--space-10);
    }

    .password-gate__card {
      padding: var(--space-8);
    }
  }
</style>
