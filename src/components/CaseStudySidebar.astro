---
interface Props {
  sections: Array<{ id: string; label: string }>;
}

const { sections } = Astro.props;
---

<aside class="case-sidebar" data-case-sidebar>
  <a href="/work" class="case-sidebar__back">← All work</a>
  <nav aria-label="Case study sections">
    <ol class="case-sidebar__list">
      {sections.map((section, i) => (
        <li class="case-sidebar__item">
          <a
            href={`#${section.id}`}
            class="case-sidebar__link"
            data-section-link
            data-section-id={section.id}
            data-active={i === 0 ? 'true' : undefined}
          >
            <span class="case-sidebar__number">
              {String(i + 1).padStart(2, '0')}
            </span>
            <span class="case-sidebar__label">{section.label}</span>
          </a>
        </li>
      ))}
    </ol>
  </nav>
</aside>

<style>
  /*
   * 220px per spec. Not a global token — scoped here to avoid
   * adding to global.css per Phase 3B-2 constraints.
   */
  .case-sidebar {
    --_sidebar-w: 220px;
    width: var(--_sidebar-w);
    position: sticky;
    top: calc(var(--header-height-desktop) + var(--space-6));
    align-self: start;
  }

  .case-sidebar__back {
    display: block;
    font-family: var(--font-sans);
    font-size: var(--font-size-meta);
    font-weight: var(--weight-regular);
    color: var(--text-muted);
    text-decoration: none;
    margin-bottom: var(--space-6);
    letter-spacing: var(--tracking-body);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .case-sidebar__back:hover {
    color: var(--text-secondary);
  }

  .case-sidebar__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .case-sidebar__link {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-2) var(--space-2) var(--space-4);
    text-decoration: none;
    border-radius: var(--radius-sm);
    position: relative;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .case-sidebar__number {
    font-family: var(--font-sans);
    font-size: var(--font-size-meta);
    font-weight: var(--weight-medium);
    color: var(--text-muted);
    flex-shrink: 0;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .case-sidebar__label {
    font-family: var(--font-sans);
    font-size: var(--font-size-meta);
    font-weight: var(--weight-regular);
    color: var(--text-muted);
    line-height: var(--leading-normal);
    transition: color var(--duration-fast) var(--ease-out);
  }

  /* Active state — per CLAUDE.md §11.1 */
  /* Phase 3B-2: first item statically active; Phase 4 toggles via sidebar-observer.js */
  .case-sidebar__link[data-active='true']::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 2px;
    height: 16px;
    background: var(--color-teal);
    border-radius: 1px;
  }

  .case-sidebar__link[data-active='true'] .case-sidebar__number {
    color: var(--color-teal);
  }

  .case-sidebar__link[data-active='true'] .case-sidebar__label {
    color: var(--text-primary);
    font-weight: var(--weight-medium);
  }

  .case-sidebar__link:hover .case-sidebar__number,
  .case-sidebar__link:hover .case-sidebar__label {
    color: var(--text-secondary);
  }
</style>
