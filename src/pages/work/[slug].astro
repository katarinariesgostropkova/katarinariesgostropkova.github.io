---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import CaseStudyLayout from '../../layouts/CaseStudyLayout.astro';
import PasswordGate from '../../components/PasswordGate.astro';
import ProseBlockquote from '../../components/ProseBlockquote.astro';

export async function getStaticPaths() {
  const entries = await getCollection('work');
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<'work'> };
const { Content } = await entry.render();
---

<CaseStudyLayout
  title={entry.data.title}
  description={entry.data.description}
  eyebrow={entry.data.eyebrow}
  heroImage={entry.data.heroImage}
  meta={entry.data.meta}
  sections={entry.data.sections}
  callout={entry.data.callout}
>
  {entry.data.private && <PasswordGate slot="gate" entry={entry} />}
  <Content components={{ blockquote: ProseBlockquote }} />
</CaseStudyLayout>
