---
import BaseLayout from '../layouts/BaseLayout.astro';
import InlineImage from '../components/InlineImage.astro';
---

<BaseLayout
  title="InlineImage test · Internal"
  description="Phase 3B-1 test harness"
>
  <main class="test-harness">
    <h1>InlineImage Test Harness</h1>
    <p>Phase 3B-1 visual verification. This page will be deleted in Phase 3B-2.</p>

    <hr />
    <h2>Test 1 — Single image, minimal (no label, no caption)</h2>

    <InlineImage
      src="/assets/images/work/non-profit/checa-hero.png"
      alt="Checa de Galicia homepage — full hero in laptop mockup"
    />

    <hr />
    <h2>Test 2 — Single image, full treatment (label + caption with bold opener)</h2>

    <InlineImage
      src="/assets/images/work/non-profit/checa-hero.png"
      alt="Checa de Galicia homepage — full hero in laptop mockup"
      label="Design · Final implementation"
      captionBold="The shipped homepage,"
      caption="showing the bilingual community welcome and the upcoming events block."
    />

    <hr />
    <h2>Test 3 — Single image, narrow (maxWidth 640px, centered)</h2>

    <InlineImage
      src="/assets/images/work/non-profit/checa-hero.png"
      alt="Checa de Galicia homepage — full hero in laptop mockup"
      label="Design · Detail view"
      caption="A narrower variant used when the image content would otherwise feel stretched."
      maxWidth="640px"
    />

    <hr />
    <p class="end-marker">End of test harness.</p>
  </main>

  <style>
    .test-harness {
      max-width: 800px;
      margin: 0 auto;
      padding: 80px var(--padding-desktop);
    }

    .test-harness h1 {
      font-family: var(--font-serif);
      font-size: var(--font-size-section);
      font-weight: var(--weight-light);
      color: var(--text-primary);
      margin-bottom: var(--space-2);
    }

    .test-harness h2 {
      font-family: var(--font-serif);
      font-size: 20px;
      font-weight: var(--weight-light);
      color: var(--text-secondary);
      margin: var(--space-10) 0 var(--space-4);
    }

    .test-harness p {
      font-family: var(--font-sans);
      font-size: var(--font-size-body);
      color: var(--text-body);
      line-height: var(--leading-normal);
    }

    .test-harness hr {
      border: none;
      border-top: 1px dashed var(--color-deep-tide-08);
      margin: var(--space-12) 0 var(--space-6);
    }

    .end-marker {
      margin-top: var(--space-20);
      color: var(--text-subtle);
    }
  </style>
</BaseLayout>
