---
import BaseLayout from '../layouts/BaseLayout.astro';
import WorkRow from '../components/WorkRow.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('work');
entries.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const work = entries.map((entry) => ({
  title:      entry.data.title,
  meta:       `${entry.data.meta.company} · ${entry.data.meta.timeline}`,
  tags:       entry.data.tags ?? [],
  excerpt:    entry.data.description,
  ctaLabel:   entry.data.private ? 'Request access →' : 'Explore →',
  ctaHref:    `/work/${entry.slug}`,
  locked:     entry.data.private,
  categories: entry.data.categories ?? [],
  thumbnail:  entry.data.heroImage
    ? { mode: 'image', src: entry.data.heroImage.src, alt: entry.data.heroImage.alt }
    : { mode: 'locked' },
}));
---

<BaseLayout
  title="Work · Katarina Riesgo Stropkova"
  description="Selected work across product design, research, and design systems."
>

  <section
    class="work-index"
    data-work-index
    aria-labelledby="work-index-heading"
  >
    <div class="work-index__inner">

      <h1 id="work-index-heading" class="work-index__heading">
        Research that shaped products.<br />
        Design that <em class="work-index__heading-accent">shipped.</em>
      </h1>

      <p class="work-index__intro">
        Some work is research-focused. Some goes all the way to delivery. All of it is grounded in evidence.
      </p>

      <div
        class="filter-row"
        data-filter-row
        role="group"
        aria-label="Filter work by category"
      >
        <button
          class="filter-pill filter-pill--active"
          data-filter-pill
          data-filter="all"
          aria-pressed="true"
          type="button"
        >All</button>
        <button
          class="filter-pill"
          data-filter-pill
          data-filter="product"
          aria-pressed="false"
          type="button"
        >Product</button>
        <button
          class="filter-pill"
          data-filter-pill
          data-filter="research"
          aria-pressed="false"
          type="button"
        >Research</button>
        <button
          class="filter-pill"
          data-filter-pill
          data-filter="design-systems"
          aria-pressed="false"
          type="button"
        >Design Systems</button>
      </div>

      <div class="work-index__rows">
        {work.map((entry) => (
          <div
            class="work-row-wrapper"
            data-work-row
            data-categories={entry.categories.join(' ')}
          >
            <WorkRow
              title={entry.title}
              meta={entry.meta}
              tags={entry.tags}
              excerpt={entry.excerpt}
              ctaLabel={entry.ctaLabel}
              ctaHref={entry.ctaHref}
              locked={entry.locked}
              thumbnail={entry.thumbnail}
            />
          </div>
        ))}
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  /* ── Page container ─────────────────────────────────────────── */
  .work-index {
    background: var(--color-canvas);
    padding: var(--space-16) 0 var(--space-12);
  }

  .work-index__inner {
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: 0 var(--padding-desktop);
  }

  @media (max-width: 1023px) {
    .work-index__inner { padding: 0 var(--padding-tablet); }
  }

  @media (max-width: 767px) {
    .work-index { padding: var(--space-12) 0 var(--space-10); }
    .work-index__inner { padding: 0 var(--padding-mobile); }
  }

  /* ── Heading ────────────────────────────────────────────────── */
  .work-index__heading {
    font-family: var(--font-serif);
    font-size: var(--font-size-hero);
    font-weight: var(--weight-light);
    color: var(--text-primary);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 var(--space-6);
    max-width: 880px;
  }

  /* Teal italic accent on 'shipped.' — per copy.md §03 annotation */
  .work-index__heading-accent {
    font-style: italic;
    color: var(--color-teal);
  }

  @media (max-width: 767px) {
    .work-index__heading { font-size: 36px; }
  }

  /* ── Intro paragraph ────────────────────────────────────────── */
  .work-index__intro {
    font-family: var(--font-sans);
    font-size: var(--font-size-subhead);
    font-weight: var(--weight-regular);
    color: var(--text-secondary);
    line-height: var(--leading-normal);
    margin: 0 0 var(--space-10);
    max-width: 640px;
  }

  /* ── Filter pill row ────────────────────────────────────────── */
  .filter-row {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-bottom: var(--space-12);
  }

  .filter-pill {
    font-family: var(--font-sans);
    font-size: var(--font-size-meta);
    font-weight: var(--weight-regular);
    letter-spacing: var(--tracking-wide);
    padding: 8px 18px;
    min-height: 36px;
    border-radius: var(--radius-full);
    background: transparent;
    color: var(--text-muted);
    border: 1px solid rgba(107, 122, 141, 0.35);
    cursor: pointer;
    transition: color var(--duration-fast) var(--ease-out),
                border-color var(--duration-fast) var(--ease-out);
  }

  .filter-pill:hover {
    color: var(--text-secondary);
    border-color: var(--text-secondary);
  }

  .filter-pill--active {
    background: var(--color-deep-tide);
    color: var(--color-canvas);
    border-color: var(--color-deep-tide);
  }

  .filter-pill--active:hover {
    color: var(--color-canvas);
    border-color: var(--color-deep-tide);
  }

  @media (max-width: 767px) {
    .filter-row {
      margin-bottom: var(--space-10);
    }
  }

  /* ── Rows wrapper ───────────────────────────────────────────── */
  .work-index__rows {
    display: flex;
    flex-direction: column;
  }

  .work-row-wrapper {
    /* WorkRow handles its own internal layout and spacing */
  }
</style>
