---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import MobileNavPill from '../../components/MobileNavPill.astro';
import ProseBlockquote from '../../components/ProseBlockquote.astro';

export async function getStaticPaths() {
  const entries = await getCollection('notebook');
  return entries
    .filter((entry) => !entry.data.isPlaceholder)
    .map((entry) => ({
      params: { slug: entry.slug },
      props: { entry },
    }));
}

const { entry } = Astro.props as { entry: CollectionEntry<'notebook'> };
const { Content } = await entry.render();

const sections = entry.data.sections ?? [];

const dateFmt = new Intl.DateTimeFormat('en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const pubDateLabel = dateFmt.format(entry.data.pubDate);
const pubDateIso = entry.data.pubDate.toISOString().slice(0, 10);
---

<BaseLayout
  title={`${entry.data.title} · Notebook · Katarina Riesgo Stropkova`}
  description={entry.data.description ?? entry.data.subtitle ?? entry.data.title}
>

  <header class="art-header" data-case-hero>
    <div class="art-header__inner">

      <p class="art-breadcrumb">
        <a href="/notebook" class="art-breadcrumb__link">← Notebook</a>
        <span class="art-breadcrumb__sep" aria-hidden="true">·</span>
        <span class="art-breadcrumb__label">Article</span>
      </p>

      <h1 class="art-title">{entry.data.title}</h1>

      {entry.data.subtitle && (
        <p class="art-subtitle">{entry.data.subtitle}</p>
      )}

      <div class="art-meta">
        <span class="art-meta__author">Katarina Riesgo Stropkova</span>
        <span class="art-meta__sep" aria-hidden="true">·</span>
        <time class="art-meta__date" datetime={pubDateIso}>
          {pubDateLabel}
        </time>
        <span class="art-meta__sep" aria-hidden="true">·</span>
        <span class="art-meta__read">8 min read</span>
        {entry.data.tags && entry.data.tags.length > 0 && (
          <>
            <span class="art-meta__sep" aria-hidden="true">·</span>
            <span class="art-meta__tags">
              {entry.data.tags.map((tag) => (
                <span class="art-tag">{tag}</span>
              ))}
            </span>
          </>
        )}
      </div>

    </div>
  </header>

  <div class="art-body">

    {sections.length > 0 && (
      <aside
        class="art-toc"
        data-case-sidebar
        aria-label="Article sections"
      >
        <a href="/notebook" class="art-toc__back">← Notebook</a>
        <nav aria-label="Jump to section">
          <ol class="art-toc__list">
            {sections.map((section, i) => (
              <li>
                <a
                  href={`#${section.id}`}
                  class="art-toc__link"
                  data-section-link
                  data-section-id={section.id}
                  data-active={i === 0 ? 'true' : undefined}
                >
                  {section.label}
                </a>
              </li>
            ))}
          </ol>
        </nav>
      </aside>
    )}

    <div class="art-content">
      <div class="art-prose">
        <Content components={{ blockquote: ProseBlockquote }} />
      </div>

      <div class="art-end-ctas">
        <a href="/work" class="btn-rose">See my work →</a>
        <a
          href="https://www.linkedin.com/in/katarinastropkova/"
          class="btn-ghost"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Connect on LinkedIn (opens in new tab)"
        >
          Connect on LinkedIn →
        </a>
      </div>
    </div>

  </div>

  {sections.length > 0 && <MobileNavPill sections={sections} />}

</BaseLayout>

<!-- Animation ⑪ (TOC active state) — sidebar-observer.js is Phase 4 work.
     Import will be added once src/scripts/sidebar-observer.js exists. -->
<script>
  import '../../scripts/mobile-nav-pill.js';
</script>

<style>
  /* ── HEADER ───────────────────────────────────── */
  .art-header {
    background: var(--color-canvas);
    padding: var(--space-16) 0 var(--space-10);
    border-bottom: var(--border-hairline) var(--border-light);
  }

  .art-header__inner {
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: 0 var(--padding-desktop);
  }

  /* ── BREADCRUMB ───────────────────────────────── */
  .art-breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin: 0 0 var(--space-6);
    font-family: var(--font-sans);
    font-size: var(--font-size-meta);
    color: var(--text-muted);
  }

  .art-breadcrumb__link {
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .art-breadcrumb__link:hover {
    color: var(--text-secondary);
  }

  .art-breadcrumb__sep,
  .art-breadcrumb__label {
    color: var(--text-subtle);
  }

  /* ── TITLE + SUBTITLE ─────────────────────────── */
  .art-title {
    font-family: var(--font-serif);
    font-size: var(--font-size-hero);
    font-weight: var(--weight-light);
    color: var(--text-primary);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 var(--space-4);
    max-width: 820px;
  }

  .art-subtitle {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 22px;
    font-weight: var(--weight-light);
    color: var(--text-secondary);
    line-height: var(--leading-snug);
    margin: 0 0 var(--space-6);
    max-width: 680px;
  }

  /* ── META ─────────────────────────────────────── */
  .art-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-sans);
    font-size: var(--font-size-meta);
    font-weight: var(--weight-regular);
    color: var(--text-muted);
  }

  .art-meta__sep {
    color: var(--text-subtle);
  }

  .art-meta__tags {
    display: inline-flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .art-tag {
    padding: var(--tag-padding);
    border-radius: var(--tag-radius);
    background: var(--tag-rose-bg);
    color: var(--tag-rose-text);
    font-family: var(--font-sans);
    font-size: var(--font-size-meta);
  }

  /* ── BODY GRID — TOC LEFT, CONTENT RIGHT ──────── */
  .art-body {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    gap: var(--space-12);
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: var(--space-10) var(--padding-desktop) var(--space-20);
    align-items: start;
  }

  /* ── TOC (left sidebar) ───────────────────────── */
  .art-toc {
    position: sticky;
    top: calc(var(--header-height-desktop) + var(--space-6));
    align-self: start;
  }

  .art-toc__back {
    display: block;
    font-family: var(--font-sans);
    font-size: var(--font-size-meta);
    font-weight: var(--weight-regular);
    color: var(--text-muted);
    text-decoration: none;
    margin-bottom: var(--space-6);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .art-toc__back:hover {
    color: var(--text-secondary);
  }

  .art-toc__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .art-toc__link {
    display: block;
    font-family: var(--font-sans);
    font-size: var(--font-size-meta);
    font-weight: var(--weight-regular);
    color: var(--text-muted);
    text-decoration: none;
    padding: var(--space-2) var(--space-3) var(--space-2) var(--space-4);
    border-radius: var(--radius-sm);
    position: relative;
    transition: color var(--duration-fast) var(--ease-out);
    line-height: var(--leading-normal);
  }

  .art-toc__link:hover {
    color: var(--text-secondary);
  }

  /* Active state — mirrors CaseStudySidebar (CLAUDE.md §11.1) */
  .art-toc__link[data-active='true'] {
    color: var(--text-primary);
  }

  .art-toc__link[data-active='true']::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 2px;
    height: 16px;
    background: var(--color-teal);
    border-radius: 1px;
  }

  /* ── PROSE ────────────────────────────────────── */
  .art-prose :global(p) {
    font-family: var(--font-sans);
    font-size: var(--font-size-body);
    font-weight: var(--weight-regular);
    color: var(--text-body);
    line-height: var(--leading-normal);
    margin: 0 0 var(--space-6);
  }

  .art-prose :global(h2) {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: var(--weight-light);
    color: var(--text-primary);
    line-height: var(--leading-snug);
    margin: var(--space-12) 0 var(--space-4);
    scroll-margin-top: calc(var(--header-height-desktop) + var(--space-6));
  }

  .art-prose :global(em) {
    font-style: italic;
  }

  .art-prose :global(strong) {
    font-weight: var(--weight-medium);
    color: var(--text-primary);
  }

  /* Article byline — defined by the .md file */
  .art-prose :global(.article-byline) {
    font-family: var(--font-sans);
    font-size: var(--font-size-body);
    color: var(--text-muted);
    margin-top: var(--space-8);
    padding-top: var(--space-8);
    border-top: var(--border-hairline) var(--border-light);
  }

  .art-prose :global(.article-byline span) {
    display: block;
    margin-top: var(--space-1);
  }

  /* ── END CTAs ─────────────────────────────────── */
  .art-end-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-top: var(--space-12);
    padding-top: var(--space-8);
    border-top: var(--border-hairline) var(--border-light);
  }

  /* Local button classes — global primitives use BEM .btn--rose */
  .btn-rose {
    background: var(--btn-rose-bg);
    color: var(--btn-rose-text);
    padding: var(--btn-padding-md);
    border-radius: var(--btn-radius);
    min-height: var(--btn-min-height);
    font-family: var(--font-sans);
    font-size: var(--font-size-meta);
    font-weight: var(--weight-regular);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .btn-rose:hover {
    transform: translateY(-1px);
  }

  .btn-ghost {
    background: transparent;
    border: 1px solid var(--btn-ghost-border);
    color: var(--btn-ghost-text);
    padding: var(--btn-padding-md);
    border-radius: var(--btn-radius);
    min-height: var(--btn-min-height);
    font-family: var(--font-sans);
    font-size: var(--font-size-meta);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    transition: color var(--duration-fast) var(--ease-out),
                border-color var(--duration-fast) var(--ease-out);
  }

  .btn-ghost:hover {
    color: var(--text-secondary);
    border-color: var(--text-secondary);
  }

  /* ── TABLET ───────────────────────────────────── */
  @media (max-width: 1199px) {
    .art-header__inner,
    .art-body {
      padding-left: var(--padding-tablet);
      padding-right: var(--padding-tablet);
    }
  }

  /* ── MOBILE — single column, TOC hidden ───────── */
  @media (max-width: 1023px) {
    .art-header__inner,
    .art-body {
      padding-left: var(--padding-mobile);
      padding-right: var(--padding-mobile);
    }

    .art-body {
      grid-template-columns: 1fr;
    }

    .art-toc {
      display: none;
    }

    .art-title {
      font-size: 36px;
    }
  }
</style>
