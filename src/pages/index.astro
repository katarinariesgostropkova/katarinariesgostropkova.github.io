---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ImpactStrip from '../components/ImpactStrip.astro';
import WorkRow from '../components/WorkRow.astro';
import { getCollection } from 'astro:content';

const workEntries = await getCollection('work');
const checaEntry = workEntries.find((e) => e.slug === 'non-profit');
const checa = checaEntry ? {
  title:    checaEntry.data.title,
  meta:     `${checaEntry.data.meta.company} · ${checaEntry.data.meta.timeline}`,
  tags:     checaEntry.data.tags ?? [],
  excerpt:  checaEntry.data.description,
  ctaLabel: 'Explore →',
  ctaHref:  `/work/${checaEntry.slug}`,
  locked:   false,
  thumbnail: checaEntry.data.heroImage
    ? { mode: 'image', src: checaEntry.data.heroImage.src, alt: checaEntry.data.heroImage.alt }
    : { mode: 'locked' },
} : null;

// Composite locked row — represents all three NDA case studies.
// Intentionally inlined here rather than stored in work.js; work.js holds
// the four individual cases used by /work. Copy from src/content/copy.md §02.
const compositeRow = {
  title: 'Featured Projects: Evidence-Based Design',
  meta: 'Avast · Oracle NetSuite',
  tags: ['UX Research', 'Enterprise ERP'],
  excerpt:
    'Three research projects from enterprise UX — covering design systems, parental controls and list interfaces. Protected by NDA.',
  ctaLabel: 'Request access →',
  ctaHref: '/work/family-space',
  private: true,
};
---

<BaseLayout title="Katarina Riesgo Stropkova — Research-Led Product Designer">
  <Hero />
  <ImpactStrip />

  <section
    class="work-teaser"
    id="work"
    data-work-teaser
    aria-labelledby="work-heading"
  >
    <div class="work-teaser__inner">
      <h2 id="work-heading" class="work-teaser__heading">
        A few things I've worked on
      </h2>

      {checa && (
        <WorkRow
          title={checa.title}
          meta={checa.meta}
          tags={checa.tags}
          excerpt={checa.excerpt}
          ctaLabel={checa.ctaLabel}
          ctaHref={checa.ctaHref}
          locked={checa.locked}
          thumbnail={checa.thumbnail}
        />
      )}

      <WorkRow
        title={compositeRow.title}
        meta={compositeRow.meta}
        tags={compositeRow.tags}
        excerpt={compositeRow.excerpt}
        ctaLabel={compositeRow.ctaLabel}
        ctaHref={compositeRow.ctaHref}
        locked={compositeRow.private}
      />
    </div>
  </section>
</BaseLayout>

<style>
  .work-teaser {
    background: var(--color-canvas);
    padding: var(--space-12) 0;
  }

  .work-teaser__inner {
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: 0 var(--padding-desktop);
  }

  .work-teaser__heading {
    font-family: var(--font-serif);
    font-size: var(--font-size-section);
    font-weight: var(--weight-light);
    color: var(--text-primary);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 var(--space-8);
  }

  @media (max-width: 1023px) {
    .work-teaser__inner {
      padding: 0 var(--padding-tablet);
    }
  }

  @media (max-width: 767px) {
    .work-teaser {
      padding: var(--space-10) 0;
    }

    .work-teaser__inner {
      padding: 0 var(--padding-mobile);
    }
  }
</style>
